            box-shadow: 0 5px 15px rgba(255,215,0,0.4);
        }

        .hero {
            background: url('Livingston.PNG') center center / cover no-repeat;
            position: relative;
            color: white;
            padding: 0;
            min-height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 8px solid rgba(255, 215, 0, 1);
        }
        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('Livingston.PNG');
            background-size: 100%;
            background-position: center 20%;
            background-repeat: no-repeat;
            opacity: 0.8;
            z-index: 0;
        }
        
        .hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(to bottom, rgba(20, 30, 0, 0.3) 40%, rgba(30, 45, 0, 0.8) 100%);
            z-index: 0;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 1200px;
            padding: 60px 40px;
        }

        .hero h1 {
            font-size: 5em;
            margin-bottom: 0px;
            font-weight: 900;
            color: rgb(255, 255, 255);
            text-shadow: 
                3px 3px 0px rgba(139, 0, 0, 1),
                -1px -1px 0px rgba(139, 0, 0, 1),
                1px -1px 0px rgba(139, 0, 0, 1),
                -1px 1px 0px rgba(139, 0, 0, 1),
                1px 1px 0px rgba(139, 0, 0, 1),
                4px 4px 8px rgba(0,0,0,0.9);
            letter-spacing: 2px;
        }

        .hero .capacity-subtitle {
            font-size: 3.2em;
            font-weight: 600;
            color: rgb(255, 230, 80);
            margin: 15px 0 0 0;
            letter-spacing: 1px;
            text-shadow: 
                2px 2px 0px rgba(139, 0, 0, 1),
                -1px -1px 0px rgba(139, 0, 0, 1),
                1px -1px 0px rgba(139, 0, 0, 1),
                -1px 1px 0px rgba(139, 0, 0, 1),
                1px 1px 0px rgba(139, 0, 0, 1),
                3px 3px 6px rgba(0,0,0,0.8);
        }
        .hero .capacity-subtitle1 {
            font-size: 2.9em;
            font-weight: 700;
            color: rgb(253, 240, 168);
            margin: 15px 0 0 0;
            letter-spacing: 1px;
            text-shadow: 
                2px 2px 0px rgba(139, 0, 0, 1),
                -1px -1px 0px rgba(139, 0, 0, 1),
                1px -1px 0px rgba(139, 0, 0, 1),
                -1px 1px 0px rgba(139, 0, 0, 1),
                1px 1px 0px rgba(139, 0, 0, 1),
                3px 3px 6px rgba(0,0,0,0.8);
        }
        .hero .capacity-subtitle2 {
            font-size: 2.1em;
            font-weight: 300;
            margin-bottom: 75px;
            font-style: italic;
            color: rgb(255, 255, 255);
            letter-spacing: 1px;
            text-shadow: 
                2px 2px 0px rgba(139, 0, 0, 1),
                -1px -1px 0px rgba(139, 0, 0, 1),
                1px -1px 0px rgba(139, 0, 0, 1),
                -1px 1px 0px rgba(139, 0, 0, 1),
                1px 1px 0px rgba(139, 0, 0, 1),
                3px 3px 6px rgba(0,0,0,0.8);
        }
        .hero p {
            font-size: 1.5em;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            font-weight: 600;
        }
        
        /* Hero Corner Chicken Videos */
        .hero-chicken-video {
            position: absolute;
            bottom: 20px;
            width: 220px;
            z-index: 10;
            border: 4px solid rgba(255, 215, 0, 1);
            border-radius: 10px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.5);
        }
        
        .hero-chicken-left {
            left: 30px;
        }
        
        .hero-chicken-right {
            right: 30px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 40px;
        }

        section {
            margin: 60px 0;
        }

        .section-title {
            font-size: 2.2em;
            color: rgba(204, 0, 0, 1);
            margin-bottom: 30px;
            text-align: center;
            font-weight: 700;
        }

        .welcome-text {
            font-size: 1.1em;
            color: rgba(85, 85, 85, 1);
            line-height: 1.8;
            margin-bottom: 40px;
            text-align: center;
            max-width: 1100px;
            margin-left: auto;
            margin-right: auto;
        }

        .area-selection {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            margin: 40px 0;
            border-top: 8px solid rgba(204, 0, 0, 1);
        }

        .area-title {
            font-size: 2em;
            color: rgba(139, 0, 0, 1);
            margin-bottom: 30px;
            font-weight: 700;
            text-align: center;
        }

        .areas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .area-card {
            background: rgba(248, 249, 250, 1);
            padding: 30px;
            border-radius: 12px;
            border-left: 5px solid rgba(255, 215, 0, 1);
            transition: all 0.3s;
            cursor: pointer;
            text-align: center;
        }

        .area-card:hover {
            background: white;
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }

        .area-name {
            font-size: 1.5em;
            font-weight: 700;
            color: rgba(139, 0, 0, 1);
            margin-bottom: 10px;
        }

        .area-info {
            font-size: 1em;
            color: rgba(102, 102, 102, 1);
            margin-bottom: 20px;
        }

        .transformer-count {
            font-size: 2em;
            font-weight: 900;
            color: rgba(204, 0, 0, 1);
            margin-bottom: 5px;
        }

        .count-label {
            font-size: 0.9em;
            color: rgba(102, 102, 102, 1);
            font-style: italic;
        }

        .coming-soon {
            opacity: 0.6;
            cursor: default;
        }

        .coming-soon:hover {
            transform: none;
            box-shadow: none;
        }

        .site-overview {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            margin: 40px 0;
            text-align: center;
        }

        .overview-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            margin-top: 30px;
        }

        .stat-box {
            padding: 20px;
        }

        .stat-number {
            font-size: 3em;
            font-weight: 900;
            color: rgba(204, 0, 0, 1);
            margin-bottom: 10px;
        }

        .stat-label {
            font-size: 1.1em;
            color: rgba(102, 102, 102, 1);
            font-weight: 600;
        }

        footer {
            background: linear-gradient(135deg, rgba(49, 65, 0, 1) 0%, rgba(70, 95, 20, 1) 100%);
            color: rgba(250, 240, 160, 1);
            padding: 40px;
            margin-top: 60px;
            border-top: 3px solid rgba(255, 215, 0, 1);
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 40px;
            flex-wrap: wrap;
        }

        .footer-text {
            flex: 1;
            text-align: center;
        }

        .footer-logos {
            display: flex;
            gap: 30px;
            align-items: center;
        }

        .footer-logo {
            height: 60px;
            width: auto;
        }

        /* Two-Column Libraries Layout */
        .libraries-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin: 40px 0;
        }

        .library-section {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            border-top: 8px solid rgba(204, 0, 0, 1);
        }

        .library-title {
            font-size: 2em;
            color: rgba(139, 0, 0, 1);
            margin-bottom: 30px;
            font-weight: 700;
            text-align: center;
        }

        /* Collapsible dropdown styling */
        details {
            margin: 15px 0;
        }

        details summary {
            cursor: pointer;
            padding: 15px 20px;
            background: rgba(248, 249, 250, 1);
            border-radius: 8px;
            border-left: 5px solid rgba(255, 215, 0, 1);
            font-size: 1.2em;
            font-weight: 600;
            color: rgba(139, 0, 0, 1);
            transition: all 0.3s;
            list-style: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        details summary::-webkit-details-marker {
            display: none;
        }

        details summary::before {
            content: '▶';
            font-size: 0.8em;
            transition: transform 0.3s;
            display: inline-block;
        }

        details[open] summary::before {
            transform: rotate(90deg);
        }

        details summary:hover {
            background: white;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

        details[open] .study-list {
            margin-top: 15px;
            padding-top: 15px;
        }

        .study-list {
            display: grid;
            gap: 15px;
        }

        .study-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 25px;
            background: rgba(248, 249, 250, 1);
            border-radius: 8px;
            border-left: 5px solid rgba(255, 215, 0, 1);
            transition: all 0.3s;
        }

        .study-item:hover {
            background: white;
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .study-info {
            flex: 1;
        }

        .study-name {
            font-size: 1.2em;
            font-weight: 700;
            color: rgba(139, 0, 0, 1);
            margin-bottom: 5px;
        }

        .study-period {
            font-size: 1em;
            color: rgba(102, 102, 102, 1);
            font-style: italic;
        }

        .study-btn {
            display: inline-block;
            padding: 12px 25px;
            background: rgba(204, 0, 0, 1);
            color: white;
            text-decoration: none;
            font-weight: 600;
            border-radius: 6px;
            transition: all 0.3s;
            text-transform: uppercase;
            font-size: 0.9em;
        }

        .study-btn:hover {
            background: rgba(139, 0, 0, 1);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(204, 0, 0, 0.3);
        }

        .placeholder-text {
            color: rgba(153, 153, 153, 1);
            font-style: italic;
            padding: 20px;
            text-align: center;
            background: rgba(248, 249, 250, 1);
            border-radius: 8px;
        }

        .highlight-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            text-align: center;
            border-top: 20px solid rgba(255, 215, 0, 1);
        }
        
        .highlight-card h3 {
            color: rgba(204, 0, 0, 1);
            margin-bottom: 8px;
            font-size: 2.0em;
            font-weight: 700;
        }
        
        .highlight-card .number {
            color: rgba(204, 0, 0, 1);
            font-size: 2.0em;
            font-weight: 700;
            margin-bottom: 5px;
            line-height: 1;
        }
        
        .highlight-card .tech-detail {
            color: rgba(51, 51, 51, 1);
            font-size: 1.8em;
            font-weight: 600;
            font-style: italic;
            margin-bottom: 15px;
            line-height: 1.3;
        }

        .highlight-card p {
            color: rgba(102, 102, 102, 1);
            font-size: 0.95em;
            line-height: 1.5;
        }

        .highlights {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin: 40px 0;
        }

        @media (max-width: 768px) {
            .libraries-container {
                grid-template-columns: 1fr;
            }
            .library-section {
                padding: 30px 20px;
            }
            .study-item {
                flex-direction: column;
                gap: 15px;
                align-items: flex-start;
            }
            header {
                flex-direction: column;
                gap: 20px;
            }

            nav {
                flex-direction: column;
                gap: 10px;
            }

            .hero h1 {
                font-size: 2.5em;
            }

            .areas-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
